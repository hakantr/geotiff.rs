  "metadataDivergences": [
    {
      "id": "geotiffjs-rational-count-loop",
      "classification": "referenceBugDataLoss",
      "rationale": "geotiff.js 3.1.0 advances the RATIONAL output loop by two while also treating the TIFF count as the number of rational pairs; skipped pairs remain zero. The Rust port intentionally preserves every pair.",
      "tags": [
        {
          "id": "318",
          "name": "WhitePoint"
        },
        {
          "id": "319",
          "name": "PrimaryChromaticities"
        },
        {
          "id": "532",
          "name": "ReferenceBlackWhite"
        }
      ]
    }
  ],
  "directoryObjectDivergence": {
    "id": "native-eager-metadata-superset",
    "classification": "nativeEagerMetadataSuperset",
    "rationale": "geotiff.js toObject() contains only fields actualized at call time and excludes DeferredArray values even after loadValue(); the Rust directory is intentionally fully actualized and therefore may contain additional losslessly decoded tags. Every JS field must still exist with the same value."
  },
  "helperDivergences": [
    {
      "id": "geotiffjs-dataslice-int64-offset",
      "classification": "referenceBugOffsetHandling",
      "rationale": "DataSlice.readInt64() is the only DataSlice reader in geotiff.js 3.1.0 that does not subtract sliceOffset, so a valid absolute offset fails for non-zero slices. Rust applies the slice offset consistently."
    },
    {
      "id": "geotiffjs-multipart-data-offset",
      "classification": "referenceBugRangePayload",
      "rationale": "geotiff.js 3.1.0 omits the boundary CRLF from startOfData and therefore slices two CRLF bytes plus only the first payload byte. Rust returns the Content-Range payload bytes exactly."
    }
  ],
  "apiDivergences": [
    {
      "id": "geotiffjs-signed-writer-payload",
      "classification": "referenceBugWriterDataLoss",
      "rationale": "geotiff.js 3.1.0 infers signed BitsPerSample and SampleFormat correctly, but its writer typeMap omits Int8Array, Int16Array and Int32Array. encodeImage then allocates eight bytes per value and stores only the low byte. Rust defaults to a lossless signed payload and exposes WriterCompatibility::GeotiffJs for exact legacy wire reproduction."
    }
  ],
  "errorDivergences": [
    {
      "id": "geotiffjs-recursive-image-index",
      "classification": "referenceBugErrorIndex",
      "rationale": "GeoTIFF.requestIFD(5) recursively discovers that IFD 1 is absent and reports index 1 instead of the requested index 5. The eager Rust directory keeps the requested index in GeoTiffImageIndexError."
    },
    {
      "id": "native-invalid-chunky-block-sample-rejection",
      "classification": "nativeInputValidation",
      "rationale": "GeoTIFFImage.getTileOrStrip ignores an out-of-range sample for chunky data and returns a block labelled with that invalid sample. Rust rejects it before indexing decoded bands, preventing an inconsistent result and possible panic."
    },
    {
      "id": "native-empty-writer-validation",
      "classification": "nativeInputValidation",
      "rationale": "The JavaScript writer dereferences the first element of empty input and leaks a TypeError. Rust returns the stable typed WriterError::EmptyData instead."
    },
    {
      "id": "native-bigtiff-reserved-field-validation",
      "classification": "nativeSpecificationValidation",
      "rationale": "geotiff.js accepts a non-zero BigTIFF reserved header word even though the BigTIFF specification requires zero. Rust rejects the malformed header without changing valid-file behavior."
    },
    {
      "id": "native-abstract-source-trait",
      "classification": "nativeTypeSystemValidation",
      "rationale": "JavaScript permits constructing BaseSource and only fails when its abstract fetch method is called. Rust's AsyncFileReader trait requires the read operation at implementation time, so this invalid object state is not constructible."
    },
    {
      "id": "native-typed-writer-metadata",
      "classification": "nativeTypeSystemValidation",
      "rationale": "JavaScript accepts dynamically typed metadata and rejects invalid GeoAsciiParams, GeoDoubleParams and GeoKey value types at runtime. WriterValue and GeoKeyValue make those invalid combinations unrepresentable in Rust."
    }
  ],
